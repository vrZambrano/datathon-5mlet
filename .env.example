# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development  # development | production

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/passos_magicos

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123

# === OpenRouter (LLM) ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_FALLBACK_MODEL=z-ai/glm-5

# === Model Configuration ===
MODEL_PATH=/app/models
CLASSIFIER_MODEL=models/classifier.pkl
CLUSTERING_MODEL=models/clustering_model.pkl
SCALER=models/scaler.pkl

# === Feature Engineering ===
RISK_THRESHOLD=0.7  # Probabilidade mínima para alerta
N_CLUSTERS=4

# === Monitoring ===
DRIFT_THRESHOLD=0.5  # Evidently AI drift score
ENABLE_MLFLOW=true
